            ];

            // --- P5 內容 ---
            const p5_zh = [
                { title: "《九月九日憶山東兄弟》", content: "獨在異鄉為異客，每逢佳節倍思親。遙知兄弟登高處，遍插茱萸少一人。" },
                { title: "《出塞》王昌齡", content: "秦時明月漢時關，萬里長征人未還。但使龍城飛將在，不教胡馬度陰山。" },
                { title: "拔苗助長", content: "從前有個人嫌禾苗長得太慢，於是把禾苗一棵棵拔高。結果禾苗枯死了，這告訴我們做事不能急於求成。" },
                { title: "科技的進步", content: "隨著科技的進步，生活變得越來越方便。智能手機讓我們可以隨時隨地與世界各地的人聯繫。" }
            ];
            const p5_en = [
                { title: "The Solar System", content: "There are eight planets in our solar system. The Earth is the third planet from the sun. We live on a beautiful blue planet." },
                { title: "A Trip to the Museum", content: "We visited the history museum last week. We learned about ancient civilizations and saw dinosaur fossils." },
