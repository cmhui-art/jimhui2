<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 學習朗讀王 - 無縫重錄版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&display=swap');
        body { font-family: 'Noto Sans TC', sans-serif; background-color: #f1f5f9; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .app-shell { width: 100%; max-width: 420px; height: 92vh; background: #ffffff; display: flex; flex-direction: column; position: relative; box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1); border-radius: 2rem; overflow: hidden; border: 6px solid #fff; }
        .scroll-area { flex: 1; overflow-y: auto; padding: 1.25rem; }
        .btn-active:active { transform: scale(0.96); transition: 0.1s; }
        .recording-glow { animation: pulse-red 1.5s infinite; }
        @keyframes pulse-red { 0% { box-shadow: 0 0 0 0px rgba(239, 68, 68, 0.4); transform: scale(1); } 70% { box-shadow: 0 0 0 15px rgba(239, 68, 68, 0); transform: scale(1.1); } 100% { box-shadow: 0 0 0 0px rgba(239, 68, 68, 0); transform: scale(1); } }
        
        /* 朗讀文字顏色標示 */
        .word-correct { color: #10b981; }
        .word-error { color: #ef4444; font-weight: 900; background-color: #fee2e2; border-radius: 4px; padding: 0 2px; }
        .word-miss { color: #94a3b8; text-decoration: underline; text-decoration-style: dotted; }
        .word-punct { color: #334155; }

        .toast { animation: slide-up 0.3s ease-out; z-index: 100; position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%); }
        @keyframes slide-up { from { transform: translateY(20px) translateX(-50%); opacity: 0; } to { transform: translateY(0) translateX(-50%); opacity: 1; } }
        
        .pet-bounce { animation: bounce 2s infinite; }
        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
        
        .progress-bar { height: 8px; border-radius: 4px; background: #e2e8f0; overflow: hidden; }
        .progress-fill { height: 100%; transition: width 0.3s; }

        /* 隱藏滾動條 */
        .scroll-area::-webkit-scrollbar { width: 0px; background: transparent; }
    </style>
</head>
<body>

