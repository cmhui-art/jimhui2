        function renderToast() {
            return state.message ? `<div class="toast bg-gray-800 text-white px-6 py-3 rounded-full font-bold shadow-2xl flex items-center gap-2"><i data-lucide="${state.message.type === 'success' ? 'check-circle' : 'info'}" class="w-4 h-4"></i>${state.message.text}</div>` : "";
