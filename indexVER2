                { title: "Healthy Habits", content: "Drinking plenty of water and eating vegetables are healthy habits. Exercise also keeps our body strong and energetic." }
            ];

            // --- P6 內容 ---
            const p6_zh = [
                { title: "《水調歌頭》蘇軾", content: "明月幾時有？把酒問青天。不知天上宮闕，今夕是何年。人有悲歡離合，月有陰晴圓缺，此事古難全。" },
                { title: "《滿江紅》岳飛", content: "怒髮衝冠，憑欄處，瀟瀟雨歇。抬望眼，仰天長嘯，壯懷激烈。三十功名塵與土，八千里路雲和月。" },
                { title: "掩耳盜鈴", content: "有一個人想偷大鐘，但他怕敲碎鐘時被人發現，於是把自己的耳朵塞住。這是自欺欺人的行為。" },
                { title: "保護環境", content: "地球是我們共同的家園。為了減少污染，我們應該積極參與回收，節約用水用電，為保護環境出一分力。" }
            ];
            const p6_en = [
                { title: "Climate Change", content: "Climate change is a global challenge. Rising temperatures affect the weather and animal habitats. We must reduce carbon emissions." },
                { title: "Artificial Intelligence", content: "AI technology is changing the world. It helps us with daily tasks and can even drive cars. We need to learn how to use it wisely." },
                { title: "A Great Leader", content: "A good leader listens to others and makes fair decisions. They inspire their team to work hard and never give up on their dreams." },
                { title: "Traveling Abroad", content: "Traveling to different countries allows us to experience new cultures. We can taste exotic foods and make friends from all over the world." }
            ];

            // 組合年級資料
            db["P1"] = { "zh-HK": p1_zh, "zh-CN": p1_zh, "en-US": p1_en };
            db["P2"] = { "zh-HK": p2_zh, "zh-CN": p2_zh, "en-US": p2_en };
            db["P3"] = { "zh-HK": p3_zh, "zh-CN": p3_zh, "en-US": p3_en };
            db["P4"] = { "zh-HK": p4_zh, "zh-CN": p4_zh, "en-US": p4_en };
            db["P5"] = { "zh-HK": p5_zh, "zh-CN": p5_zh, "en-US": p5_en };
            db["P6"] = { "zh-HK": p6_zh, "zh-CN": p6_zh, "en-US": p6_en };

            return db;
        };
        const READING_DB = generateDB();
        
        // --- 成語題庫 ---
        const IDIOMS = [
            { q: "形容色彩鮮艷，式樣繁多？", a: "五光十色", options: ["五光十色", "一絲不苟", "鳥語花香", "各式各樣"] },
            { q: "形容說話或辦事有條有理，一點兒也不混亂？", a: "井井有條", options: ["井井有條", "胡言亂語", "半途而廢", "畫蛇添足"] },
            { q: "鳥兒歌唱，花開芬芳。形容春天的美好景象？", a: "鳥語花香", options: ["風雨交加", "鳥語花香", "千變萬化", "津津有味"] },
            { q: "團結一致，共同努力？", a: "同心協力", options: ["同心協力", "自相矛盾", "守望相助", "半途而廢"] },
            { q: "為了對付盜賊或災禍，鄰居互相幫忙？", a: "守望相助", options: ["拔苗助長", "守望相助", "對牛彈琴", "亡羊補牢"] },
            { q: "形容趣味濃厚的樣子。也指吃得很有味道？", a: "津津有味", options: ["津津有味", "不慌不忙", "一絲不苟", "口若懸河"] },
            { q: "比喻自己的言行前後互相抵觸？", a: "自相矛盾", options: ["畫蛇添足", "自相矛盾", "對牛彈琴", "掩耳盜鈴"] },
            { q: "形容人說話滔滔不絕，像流水一樣？", a: "口若懸河", options: ["口若懸河", "沈默寡言", "井井有條", "一字千金"] },
            { q: "比喻做事非常認真，一點也不馬虎？", a: "一絲不苟", options: ["一絲不苟", "馬馬虎虎", "半途而廢", "粗心大意"] },
            { q: "做事做到一半就停止，比喻不能堅持到底？", a: "半途而廢", options: ["半途而廢", "堅持不懈", "同心協力", "持之以恆"] },
            { q: "比喻多此一舉，反而弄巧成拙？", a: "畫蛇添足", options: ["畫龍點睛", "畫蛇添足", "錦上添花", "亡羊補牢"] },
            { q: "比喻不主動努力，存僥倖心理，希望得到意外的收穫？", a: "守株待兔", options: ["守株待兔", "刻舟求劍", "緣木求魚", "掩耳盜鈴"] },
            { q: "比喻出了問題以後想辦法補救，可以防止繼續受損失？", a: "亡羊補牢", options: ["亡羊補牢", "防微杜漸", "未雨綢繆", "亡魂喪膽"] },
            { q: "形容態度鎮定，不慌張，不急促？", a: "不慌不忙", options: ["手忙腳亂", "不慌不忙", "津津有味", "千變萬化"] },
            { q: "形容事物變化非常多？", a: "千變萬化", options: ["千變萬化", "一成不變", "井井有條", "各式各樣"] }
        ];

        // --- 狀態管理 ---
        const defaultState = {
            view: 'login',
            coins: 100, grade: 'P1', lang: 'zh-HK', mathType: 'add',
            currentText: null, isMicOn: false, message: null, evalResult: null,
            mathGame: { q: '', a: 0, type: 'add' }, idiomGame: { current: 0 },
            pet: { 
                hunger: 80, hygiene: 90, exp: 0, level: 1, 
                badges: 0, lastTick: Date.now(), 
                goodStateSince: Date.now(), badStateSince: null 
            }
        };

        let state = { ...defaultState };
        let currentUser = null; 
        let recognitionInstance = null;

        // --- 解決 Module Scope 問題 ---
        window.setGrade = (g) => { stopTTS(); state.grade = g; window.setView('reading-lang'); };
        window.setLang = (l) => { stopTTS(); state.lang = l; window.setView('reading-list'); };
        window.playText = (index) => { 
            stopTTS();
            state.currentText = READING_DB[state.grade][state.lang][index]; 
            window.setView('reading-play'); 
        };
        window.retryReading = () => { stopTTS(); state.evalResult = null; render(); };

        // --- Firebase 雲端存檔 ---
        async function loadDataFromCloud(username) {
            try {
                if (!auth.currentUser) {
                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await signInWithCustomToken(auth, __initial_auth_token);
                    } else {
                        await signInAnonymously(auth);
                    }
                }

                const docRef = getUserDocRef(username);
                const docSnap = await getDoc(docRef);

                if (docSnap.exists()) {
                    const parsed = docSnap.data();
                    state = { ...defaultState, ...parsed, pet: { ...defaultState.pet, ...parsed.pet } };
                    showMessage(`歡迎回來，${username}！`, 'success');
                } else {
                    state = { ...defaultState, view: 'home' }; 
                    await setDoc(docRef, state);
                    showMessage(`歡迎新同學：${username}！`, 'success');
                }
                
                state.view = 'home';
                state.isMicOn = false; 
                state.message = null; 
                state.evalResult = null;
                
                catchUpTime(); 
                render();
            } catch (error) {
                console.error("讀取資料失敗:", error);
                if (error.code === 'permission-denied') {
                    showMessage("資料庫權限不足！請記得去 Firebase 更新 Rules 喔！", 'error');
                } else {
                    showMessage("系統連線失敗，請稍後再試", 'error');
                }
                state.view = 'login';
                render();
            }
        }

        async function saveState() {
            if (!currentUser || !auth.currentUser) return; 
            
            const toSave = { ...state };
            delete toSave.currentText;
            delete toSave.isMicOn;
            delete toSave.message;
            delete toSave.evalResult;
            delete toSave.view; 
            
            try {
                const docRef = getUserDocRef(currentUser);
                await setDoc(docRef, toSave);
            } catch (error) {
                console.error("儲存資料失敗:", error);
                if (error.code === 'permission-denied') {
                    showMessage("存檔失敗：權限不足", 'error');
                }
            }
        }

        // --- 登入與登出 ---
        window.handleLogin = () => {
            const input = document.getElementById('usernameInput');
            const username = input.value.trim();
            
            if (!username) return showMessage("請輸入你的名字！", 'error');
            if (username.length > 10) return showMessage("名字太長了，請使用簡短名稱", 'error');
            
            sessionStorage.setItem('readaloud_user', username);
            
            currentUser = username;
            state.view = 'loading';
            render();
            
            loadDataFromCloud(username);
        };

        window.handleLogout = () => {
            stopTTS();
            sessionStorage.removeItem('readaloud_user');
            currentUser = null;
            state = { ...defaultState, view: 'login' };
            render();
        };

        // --- 核心邏輯 (寵物時間流逝) ---
        function catchUpTime() {
            if (!currentUser) return;
            const now = Date.now();
            const msPerHour = 3600 * 1000;
            let hoursPassed = Math.floor((now - state.pet.lastTick) / msPerHour);

            if (hoursPassed > 0) {
                for(let i=0; i<hoursPassed; i++) {
                    state.pet.hunger = Math.max(0, state.pet.hunger - 2);
                    state.pet.hygiene = Math.max(0, state.pet.hygiene - 2);
                    const isGood = state.pet.hunger >= 80 && state.pet.hygiene >= 80;
                    const tickTime = state.pet.lastTick + ((i+1) * msPerHour);

                    if (isGood) {
                        state.pet.badStateSince = null;
                        if (!state.pet.goodStateSince) state.pet.goodStateSince = tickTime;
                        if (tickTime - state.pet.goodStateSince >= 24 * msPerHour) {
                            state.pet.badges = Math.min(5, state.pet.badges + 1);
                            state.pet.goodStateSince = tickTime;
                        }
                    } else {
                        state.pet.goodStateSince = null;
                        if (!state.pet.badStateSince) state.pet.badStateSince = tickTime;
                        if (tickTime - state.pet.badStateSince >= 24 * msPerHour) {
                            state.pet.badges = Math.max(0, state.pet.badges - 1);
                            state.pet.badStateSince = tickTime;
                        }
                    }
                }
                state.pet.lastTick += hoursPassed * msPerHour;
                saveState();
            }
        }

        setInterval(() => {
            if (currentUser && state.view === 'home') {
                catchUpTime();
                render();
            }
        }, 60000);

        function updatePetStatusImmediate() {
            const isGood = state.pet.hunger >= 80 && state.pet.hygiene >= 80;
            const now = Date.now();
            if (isGood) {
                state.pet.badStateSince = null;
                if (!state.pet.goodStateSince) state.pet.goodStateSince = now;
            } else {
                state.pet.goodStateSince = null;
                if (!state.pet.badStateSince) state.pet.badStateSince = now;
            }
            saveState();
        }

        // --- 介面控制 ---
        window.setView = (v) => { 
            stopTTS(); 
            state.view = v; 
            state.message = null; 
            if(v !== 'reading-play' || !state.evalResult) state.evalResult = null; 
            if (v === 'idiom') window.startIdiom();
            render(); 
        };

        function showMessage(text, type = 'info') {
            state.message = { text, type };
            render();
            setTimeout(() => { if (state.message?.text === text) { state.message = null; render(); } }, 4000);
        }

        // --- 朗讀評估 (加入多音字與異讀音智慧容錯) ---
        window.runAssessment = (userText) => {
            // 【關鍵修復點 1】：只要進入評分階段，代表已經成功拿到結果
            // 立刻將麥克風狀態設為 false，這樣 onend 觸發時就不會誤以為是異常結束
            state.isMicOn = false; 

            const rawOriginal = state.currentText.content;
            const recognized = userText.replace(/[，。？！、：；「」\s]/g, "").toLowerCase();
            let resultWords = [], errors = 0, misses = 0, recIndex = 0;

            const isCharMatch = (expected, actual) => {
                if (expected === actual) return true;
                const alts = {
                    '覺': '教角各較交覺', '少': '小兆少', '行': '航衡恆形行', '長': '掌獎場腸常長',
                    '和': '禾禍臥汗和', '冠': '官館貫冠', '塞': '賽色塞', '將': '蔣獎江將',
                    '還': '環寰灣還', '難': '蘭難', '分': '份分', '地': '的得地', '的': '地得的', '得': '地的得',
                    '著': '着住著', '着': '著住着', '那': '哪那', '哪': '那哪', '只': '隻只', '隻': '只隻',
                    '裡': '裏里裡', '裏': '裡里裏', '里': '裡裏里'
                };
                return alts[expected] && alts[expected].includes(actual);
            };

            for (let i = 0; i < rawOriginal.length; i++) {
                const char = rawOriginal[i];
                if (/[，。？！、：；「」\s]/.test(char)) { resultWords.push({ char, status: 'punct' }); continue; }
                if (recIndex < recognized.length) {
                    if (isCharMatch(char.toLowerCase(), recognized[recIndex])) {
                        resultWords.push({ char, status: 'correct' });
                    } else { 
                        resultWords.push({ char, status: 'error' }); 
                        errors++; 
                    }
                    recIndex++;
                } else { resultWords.push({ char, status: 'miss' }); misses++; }
            }

            const totalFaults = errors + misses;
            let reward = totalFaults === 0 ? 30 : (totalFaults <= 3 ? 20 : (totalFaults <= 6 ? 10 : 0));

            state.evalResult = { words: resultWords, score: reward };
            if (reward > 0) {
                state.coins += reward;
                addExp(reward);
                showMessage(`太棒了！獲得 ${reward} 金幣`, 'success');
                saveState();
            } else showMessage(`有 ${totalFaults} 個錯漏字，再試一次吧！`, 'error');
            render();
        };

        window.toggleMic = () => {
            stopTTS(); 
            
            const Speech = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!Speech) return showMessage("瀏覽器不支援語音功能", "error");

            // 如果目前正在錄音中，表示使用者想手動停止
            if (state.isMicOn) {
                if (recognitionInstance) {
                    try { recognitionInstance.stop(); } catch(e){}
                }
                return; 
            }

            // 【關鍵修復點 2】：在建立新的錄音前，確保舊的完全被中斷(abort)，避免卡住在背景
            if (recognitionInstance) {
                try { recognitionInstance.abort(); } catch(e){}
                recognitionInstance = null;
            }

            // 清理舊狀態
            state.evalResult = null; 
            state.message = null; 
            render();

            recognitionInstance = new Speech();
            recognitionInstance.lang = state.lang;
            recognitionInstance.interimResults = false;
            
            recognitionInstance.onstart = () => { state.isMicOn = true; render(); };
            recognitionInstance.onresult = (e) => window.runAssessment(e.results[0][0].transcript);
            
            recognitionInstance.onerror = (e) => {
                state.isMicOn = false;
                recognitionInstance = null;
                // 用戶主動放棄或 abort 時不需要報錯
                if (e.error === 'aborted') return;
                
                if (e.error === 'not-allowed' || e.error === 'service-not-allowed') {
                    showMessage("請允許瀏覽器使用麥克風喔！", "error");
                } else if (e.error === 'no-speech') {
                    // 交給 onend 處理無聲提示，避免重複報錯
                } else {
                    showMessage("錄音發生錯誤，請重試", "error");
                }
                render();
            };
            
            recognitionInstance.onend = () => { 
                // 只有在 isMicOn 為 true 的情況下結束，才代表是不正常的提早中斷
                if (state.isMicOn) {
                    state.isMicOn = false; 
                    recognitionInstance = null;
                    // 加入畫面判斷，確保只在朗讀畫面才提示錯誤
                    if (!state.evalResult && !state.message && state.view === 'reading-play') {
                        showMessage("未偵測到聲音，請再試一次", "error");
                    }
                    render(); 
                }
            };
            
            try {
                recognitionInstance.start();
            } catch (err) {
                console.error("麥克風啟動失敗", err);
            }
        };

        window.speak = () => {
            stopTTS();
            let txtToSpeak = state.currentText.content;
            
            if (state.currentText.tts && state.currentText.tts[state.lang]) {
                txtToSpeak = state.currentText.tts[state.lang];
            }
            
            const u = new SpeechSynthesisUtterance(txtToSpeak);
            u.lang = state.lang;
            window.speechSynthesis.speak(u);
        };

        // --- 遊戲邏輯 ---
        window.startIdiom = () => {
            state.idiomGame.current = Math.floor(Math.random() * IDIOMS.length);
            const q = IDIOMS[state.idiomGame.current];
            q.shuffledOptions = [...q.options].sort(() => Math.random() - 0.5);
        };

        window.checkIdiom = (choice) => {
            stopTTS();
            const q = IDIOMS[state.idiomGame.current];
            if (choice === q.a) { state.coins += 10; addExp(10); showMessage("正確！+10 💰", "success"); } 
            else showMessage("正確是：" + q.a, "error"); 
            saveState();
            setTimeout(() => { window.startIdiom(); render(); }, 1500);
            render();
        };

        // 心算邏輯
        window.setMathType = (type) => {
            stopTTS();
            state.mathType = type;
            window.startMath();
            window.setView('math');
        };

        window.startMath = () => {
            let n1, n2, q, a;
            if (state.mathType === 'add') {
                n1 = Math.floor(Math.random() * 10) + 1;
                n2 = Math.floor(Math.random() * 10) + 1;
                q = `${n1} + ${n2}`; a = n1 + n2;
            } else if (state.mathType === 'sub') {
                n1 = Math.floor(Math.random() * 10) + 1;
                n2 = Math.floor(Math.random() * 10) + 1;
                if (n1 < n2) { const temp = n1; n1 = n2; n2 = temp; } 
                q = `${n1} - ${n2}`; a = n1 - n2;
            } else if (state.mathType === 'mul') {
                n1 = Math.floor(Math.random() * 10) + 1;
                n2 = Math.floor(Math.random() * 10) + 1;
                q = `${n1} × ${n2}`; a = n1 * n2;
            } else if (state.mathType === 'div') {
                a = Math.floor(Math.random() * 10) + 1; 
                n2 = Math.floor(Math.random() * 10) + 1; 
                n1 = a * n2; 
                q = `${n1} ÷ ${n2}`; 
            }
            state.mathGame = { q, a };
        };

        window.checkMath = (val) => {
            stopTTS();
            if (val === '') return;
            if (parseInt(val) === state.mathGame.a) {
