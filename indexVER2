            const p4_en = [
                { title: "A New Hobby", content: "I started learning how to draw. It is very relaxing. I want to paint a beautiful picture for my parents." },
                { title: "Sports Day", content: "Our school had a sports day. I ran in the relay race. Our team won a gold medal!" },
